# Stage 1 — build the React SPA
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# Write .env so Vite's loadEnv picks up overrides at build time
ARG VITE_API_URL
RUN printf "VITE_API_URL=%s\nVITE_BASE_PATH=/\n" "${VITE_API_URL}" > .env

RUN npm run build

# Stage 2 — lightweight static file server
FROM node:20-alpine
WORKDIR /app
RUN npm install -g serve
COPY --from=builder /app/dist ./dist
EXPOSE 3000
CMD ["serve", "-s", "dist", "-l", "3000"]
